# Tailscale authentication key (get from https://login.tailscale.com/admin/settings/keys)
# Never commit this file - add to .gitignore
TS_AUTHKEY=your_tailscale_auth_key_here

# Optional: Set hostname for the container (defaults to windsurf-dev)
# TS_HOSTNAME=windsurf-dev

# Optional: Additional Tailscale settings
# TS_EXTRA_ARGS=--advertise-exit-node